            f.write("-" * 70 + "\n")
            f.write("OVERALL STATISTICS\n")
            f.write("-" * 70 + "\n")
            f.write(f"Total Physicians Analyzed: {len(df)}\n")
            f.write(f"Eligible for Clustering: {df['eligible_for_clustering'].sum()}\n")
            f.write(f"Insufficient Data: {(~df['eligible_for_clustering']).sum()}\n\n")
            
            f.write("-" * 70 + "\n")
            f.write("DATA AVAILABILITY BY BUCKET\n")
            f.write("-" * 70 + "\n")
