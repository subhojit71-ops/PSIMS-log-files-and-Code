            f.write(f"Academic Data Available: {df['academic_data_available'].sum()} ({df['academic_data_available'].sum()/len(df)*100:.1f}%)\n")
            f.write(f"Social Media Data Available: {df['social_media_data_available'].sum()} ({df['social_media_data_available'].sum()/len(df)*100:.1f}%)\n")
            f.write(f"Recognition Data Available: {df['recognition_data_available'].sum()} ({df['recognition_data_available'].sum()/len(df)*100:.1f}%)\n\n")
            
            f.write("-" * 70 + "\n")
            f.write("AVERAGE SCORES\n")
            f.write("-" * 70 + "\n")
            f.write(f"Engagement Score: {df['engagement_score'].mean():.2f} (Range: {df['engagement_score'].min():.2f} - {df['engagement_score'].max():.2f})\n")
            f.write(f"Academic Score: {df['academic_score'].mean():.2f} (Range: {df['academic_score'].min():.2f} - {df['academic_score'].max():.2f})\n")
            f.write(f"Social Media Score: {df['social_media_score'].mean():.2f} (Range: {df['social_media_score'].min():.2f} - {df['social_media_score'].max():.2f})\n")
            f.write(f"Recognition Score: {df['recognition_score'].mean():.2f} (Range: {df['recognition_score'].min():.2f} - {df['recognition_score'].max():.2f})\n\n")
            
            if cluster_profiles:
                f.write("-" * 70 + "\n")
                f.write("CLUSTER DISTRIBUTION\n")
                f.write("-" * 70 + "\n")
                for profile in cluster_profiles:
                    pct = (profile['count'] / len(df)) * 100
                    f.write(f"\n{profile['cluster_name']}\n")
                    f.write(f"  Size: {profile['count']} physicians ({pct:.1f}%)\n")
                    f.write(f"  Avg Engagement: {profile['avg_engagement']:.2f}\n")
                    f.write(f"  Avg Academic: {profile['avg_academic']:.2f}\n")
                    f.write(f"  Avg Social Media: {profile['avg_social_media']:.2f}\n")
                    f.write(f"  Avg Recognition: {profile['avg_recognition']:.2f}\n")
            
            # Bucket distribution
            f.write("\n" + "-" * 70 + "\n")
            f.write("BUCKET DISTRIBUTION\n")
            f.write("-" * 70 + "\n")
            bucket_dist = df['buckets_with_data'].value_counts().sort_index()
            for buckets, count in bucket_dist.items():
                pct = (count / len(df)) * 100
                f.write(f"{int(buckets)} bucket(s): {count} physicians ({pct:.1f}%)\n")
            
            f.write("\n" + "=" * 70 + "\n")
        
        self.log(f"   ✓ Saved: {summary_file}")
        
        return output_file, profiles_file if cluster_profiles else None, summary_file
    
    def run_analysis(self, n_clusters=6):
        """Execute complete analysis pipeline"""
        self.log("\n" + "="*60)
        self.log("🚀 STARTING PSIMS ANALYSIS")
        self.log("="*60)
        
        self.load_all_data()
        aggregated = self.aggregate_by_uin()
        
        if aggregated.empty:
            self.log("\n❌ No data to analyze")
            return None, None, None
        
        scored = self.calculate_scores(aggregated)
        clustered, profiles = self.perform_clustering(scored, n_clusters)
        
        output_file, profiles_file, summary_file = self.generate_output(clustered, profiles)
        
        self.log("\n" + "="*60)
        self.log("✅ ANALYSIS COMPLETE!")
        self.log("="*60)
        
        return output_file, profiles_file, summary_file


